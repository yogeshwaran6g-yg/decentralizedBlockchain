{
    "name": "Node.js & PostgreSQL",
    "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
    "features": {
        "ghcr.io/devcontainers/features/postgresql:1": {
            "version": "16"
        }
    },
    "forwardPorts": [
        3000,
        4000,
        5432
    ],
    "postCreateCommand": "npm install && npm run db:setup"
}